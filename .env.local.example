# P707 — 어드민 관리 페이지 (서버 전용 env, NEXT_PUBLIC_ 아님 = 브라우저 비노출)
# 로컬: 이 파일을 .env.local 로 복사해 채움. prod: Vercel → Settings → Environment Variables.

# 어드민 로그인 비밀번호 (운영자만 아는 값)
ADMIN_PANEL_PASSWORD=change-me-strong-password

# 세션 쿠키 HMAC 서명 비밀키 (랜덤 32바이트+ 권장: openssl rand -base64 32)
ADMIN_SESSION_SECRET=change-me-random-secret

# 백엔드 X-Admin-Token (= 백엔드 SAJULAB_ADMIN_TOKEN 과 동일 값)
ADMIN_API_TOKEN=

# 백엔드 베이스 URL. api.sajulab.ai 는 아직 DNS 미연결 → 실제 백엔드는 Cloud Run.
# 코드 기본값도 Cloud Run 이므로 미설정이어도 동작. 로컬 백엔드면 http://localhost:8000
BACKEND_BASE_URL=https://sajulab-backend-qqjgnsi3ja-du.a.run.app
